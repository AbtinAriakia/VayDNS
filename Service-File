[Unit]
Description=VayDNS Tunnel Server
Documentation=https://github.com/net2share/vaydns
After=network-online.target

[Service]
Type=exec
User=USER
ExecStart=/usr/local/bin/vaydns-server \
    -udp :5300 \
    -domain t.example.com \
    -upstream 127.0.0.1:22 \
    -privkey-file /etc/vaydns/server.key \
    -mtu 1452 \
    -record-type TYPE
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
