[Unit]
Description=VayDNS Tunnel
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/vaydns-server \
    -udp :5300 \
    -domain t.example.com \
    -upstream 127.0.0.1:22 \
    -privkey-file /etc/vaydns/server.key \
    -mtu 1232 \
    -record-type TYPE \
    -log-level info
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
