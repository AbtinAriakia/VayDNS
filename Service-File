[Unit]
Description=VayDNS Server Tunnel
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/vaydns-server \
    -udp :5300 \
    -domain t.yourdomain.com \
    -upstream 127.0.0.1:22 \
    -privkey-file /etc/vaydns/server.key \
    -record-type TYPE
Restart=on-failure
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
