[Unit]
Description=VayDNS Tunnel Server
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/vf
ExecStart=/root/vf/vaydns-server -udp :5300 -privkey-file server.key -domain $ -upstream 127.0.0.1:$ -mtu 1232 -record-type $
Restart=always
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
