[Unit]
Description=VayDNS Tunnel
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/vaydns-server \
    -udp :5300 \
    -domain a.hjp.lol \
    -upstream 127.0.0.1:25267 \
    -privkey-file /etc/vaydns/server.key \
    -record-type null
Restart=on-failure
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
